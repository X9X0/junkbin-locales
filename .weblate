format_version: 1

project:
  name: Junkbin.io
  slug: junkbin-io
  web: https://junkbin.io

components:
  - name: Frontend UI
    slug: frontend-ui
    filemask: frontend/locales/*/translation.json
    template: frontend/locales/en/translation.json
    file_format: json-nested
    source_language: en
    license: CC-BY-SA-4.0
    push_on_commit: false

  - name: Backend
    slug: backend
    filemask: backend/locale/*/LC_MESSAGES/django.po
    file_format: po
    source_language: en
    license: CC-BY-SA-4.0
    push_on_commit: false

  "guidelines": {
    "title": "DIRECTIVES COMMUNAUTAIRES",
    "subtitle": "Normes de contribution à la communauté Junkbin.io",
    "section_mission": "NOTRE MISSION",
    "section_content": "NORMES DE CONTENU",
    "section_communication": "NORMES DE COMMUNICATION",
    "section_prohibited": "CONTENU INTERDIT",
    "section_enforcement": "APPLICATION",
    "section_appeals": "APPELS",
    "last_updated": "Dernière mise à jour : février 2026",
    "mission_text": "Junkbin.io is a community-driven database for electronic component documentation, supporting the Right to Repair movement. We believe repair information should be freely accessible. Every contribution helps someone fix a device instead of throwing it away. These guidelines exist to keep the community productive, respectful, and focused on that goal.",
    "content_01_title": "Accuracy matters.",
    "content_01_text": "Double-check part numbers, manufacturer names, and reference designators before submitting. If you're unsure, note it in the description.",
    "content_02_title": "Cite your sources.",
    "content_02_text": "When uploading schematics or datasheets, indicate where they came from (manufacturer site, community reverse-engineering, etc.).",
    "content_03_title": "No duplicates.",
    "content_03_text": "Search before submitting a new product or component. If it already exists, add to the existing entry instead.",
    "content_04_title": "Quality photos.",
    "content_04_text": "When uploading PCB images, use good lighting and focus. Clear images help others identify components.",
    "content_05_title": "Stay on topic.",
    "content_05_text": "Comments should relate to the product, its components, or repair information. Save off-topic discussions for messages.",
    "comm_01_title": "Be respectful.",
    "comm_01_text": "Disagreements about component identification are normal. Discuss the data, not the person.",
    "comm_02_title": "No harassment.",
    "comm_02_text": "Targeted, repeated, or unwelcome messages to another user are not tolerated. Use the block feature if needed.",
    "comm_03_title": "No hate speech.",
    "comm_03_text": "Slurs, discriminatory language, and content promoting hatred against any group are prohibited.",
    "comm_04_title": "No spam.",
    "comm_04_text": "Don't send unsolicited promotional messages or post repetitive content.",
    "prohibited_intro": "The following will result in content removal and may lead to account action:",
    "prohibited_01": "Deliberately incorrect technical information",
    "prohibited_02": "Spam, advertising, or promotional content",
    "prohibited_03": "Copyright-infringing material without fair use basis",
    "prohibited_04": "NSFW, violent, or graphic content",
    "prohibited_05": "Harassment, threats, or doxxing",
    "prohibited_06": "Hate speech, slurs, or discriminatory language",
    "prohibited_07": "Impersonation of other users or organizations",
    "enforcement_intro": "We use a transparent, graduated enforcement system:",
    "enforcement_report_label": "REPORT",
    "enforcement_report_text": "Any user can report content or messages that violate these guidelines. Reports are reviewed by moderators.",
    "enforcement_strike_label": "STRIKE",
    "enforcement_strike_text": "Valid reports result in a strike on the reported user's account. You'll be notified by email when you receive a strike.",
    "enforcement_review_label": "REVIEW",
    "enforcement_review_text": "At 3 strikes, your account is automatically flagged for moderator review. Reviews can result in:",
    "outcome_cleared": "CLEARED",
    "outcome_cleared_text": "No action needed, strikes were minor or context-dependent",
    "outcome_warning": "WARNING",
    "outcome_warning_text": "Formal warning issued, no account restrictions",
    "outcome_restricted": "RESTRICTED",
    "outcome_restricted_text": "Trusted status revoked, contributions require moderation",
    "outcome_suspended": "SUSPENDED",
    "outcome_suspended_text": "Account deactivated",
    "appeals_text_before": "If you believe a moderation action was made in error, you can appeal by emailing",
    "appeals_email": "appeals@junkbin.io",
    "appeals_text_after": "with your username and a description of the situation. Appeals are reviewed by a different moderator than the one who took the original action. We aim to respond within 48 hours."

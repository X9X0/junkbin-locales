  "guidelines": {
    "title": "ПРАВИЛА СООБЩЕСТВА",
    "subtitle": "Стандарты участия в сообществе Junkbin.io",
    "section_mission": "НАША МИССИЯ",
    "section_content": "СТАНДАРТЫ КОНТЕНТА",
    "section_communication": "СТАНДАРТЫ ОБЩЕНИЯ",
